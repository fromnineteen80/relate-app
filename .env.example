# Supabase (required for auth + database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (required for payments)
# Use TEST keys for development: https://dashboard.stripe.com/test/apikeys
# Test card: 4242 4242 4242 4242, any future date, any CVC
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Anthropic (required for Claude Advisor)
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Email (for partner invitations)
RESEND_API_KEY=

# Mock modes (for testing without APIs)
NEXT_PUBLIC_MOCK_AUTH=false
NEXT_PUBLIC_MOCK_PAYMENTS=false
NEXT_PUBLIC_MOCK_ADVISOR=false

# Set to true to bypass payment (grants premium access to everyone)
NEXT_PUBLIC_TEST_FULL_ACCESS=false
